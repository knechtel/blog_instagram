<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Posts</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #fafafa;
    }

    header {
      background-color: #ffffff;
      border-bottom: 1px solid #dbdbdb;
      padding: 15px;
      text-align: center;
      font-size: 20px;
      font-weight: bold;
    }

    .container {
      max-width: 500px;
      margin: 20px auto;
    }

    .notice {
      color: green;
      text-align: center;
      margin-bottom: 15px;
    }

    .post-card {
      background: #fff;
      border: 1px solid #dbdbdb;
      border-radius: 8px;
      margin-bottom: 20px;
      overflow: hidden;
    }

    .post-header {
      padding: 10px;
      font-weight: bold;
      border-bottom: 1px solid #efefef;
    }

    .post-body {
      padding: 15px;
      font-size: 14px;
    }

    .post-actions {
      padding: 10px;
      border-top: 1px solid #efefef;
    }

    .btn {
      display: inline-block;
      padding: 6px 10px;
      background: #0095f6;
      color: white;
      text-decoration: none;
      border-radius: 5px;
      font-size: 13px;
    }

    .btn:hover {
      background: #0077cc;
    }

    .new-post {
      text-align: center;
      margin-top: 20px;
    }
  </style>
</head>

<body>

<header>
  Instagram Feed
</header>

<div class="container">

  <p class="notice"><%= notice %></p>

  <h2 style="text-align:center;">Posts</h2>

  <div id="posts">
    <% @posts.each do |post| %>
      <div class="post-card">

        <div class="post-header">
          Usuário
        </div>

        <div class="post-body">
          <%= render post %>
        </div>

        <div class="post-actions">
          <%= link_to "Ver post", post, class: "btn" %>
        </div>

      </div>
    <% end %>
  </div>

  <div class="new-post">
    <%= link_to "Novo post", new_post_path, class: "btn" %>
  </div>

</div>

</body>
</html>